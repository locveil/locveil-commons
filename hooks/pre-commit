#!/bin/sh
# Locveil pre-commit hook: --check only — hooks never mutate the tree.
# scope-guard: process/ledger-discipline.md §4 · contract-guard: process/contracts.md §4.
# Install once:  git config core.hooksPath hooks
python3 packages/scope-guard/scope_guard.py --config .scope-guard.toml || exit 1
python3 packages/contract-guard/contract_guard.py --check || exit 1
# HK-12 §5 pre-commit stage: staleness WARNS here, never blocks (fail-on none; the
# trailing || true also covers a missing/broken config — a hook must not brick commits).
python3 packages/repin/repin.py --check --fail-on none || true
exit 0
