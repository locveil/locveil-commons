# Copy to your project's eval/.env (or export) before running promptfoo.

# DeepSeek judge (OpenAI-compatible). Required for any llm-rubric / g-eval assertion.
DEEPSEEK_API_KEY=sk-...

# wb-mqtt-voice streaming ASR endpoint (IRENE_WEB_PORT default 6000)
WS_AUDIO_URL=ws://localhost:6000/ws/audio

# MQTT broker (wb-mqtt-bridge and other MQTT consumers)
MQTT_HOST=localhost
MQTT_PORT=1883
