{
  "name": "locveil-workbench",
  "version": "0.1.1",
  "description": "The Locveil Workbench shell (IMPL-1): chrome + plugin contract + HK-11 runtime assembly (native ESM + import map).",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "src/contract.ts"
  ],
  "exports": {
    "./contract": {
      "types": "./src/contract.ts"
    }
  },
  "scripts": {
    "build:vendor": "node scripts/build-vendor.mjs",
    "smoke:vendor": "node scripts/smoke-vendor.mjs",
    "build:shell": "vite build",
    "build:demo": "node scripts/build-demo.mjs",
    "build": "npm run build:vendor && npm run smoke:vendor && npm run build:shell && npm run build:demo",
    "dev": "vite build --watch",
    "serve": "node scripts/serve.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src demo-plugin/src scripts --max-warnings 0",
    "check": "npm run typecheck && npm run lint"
  },
  "dependencies": {
    "locveil-ui-kit": "file:../ui-kit",
    "lucide-react": "^0.453.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.9",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
